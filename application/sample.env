# Copy this file to ../.env (project root) and fill in the values.
# Do NOT commit .env — it is gitignored.

# ── LLM ─────────────────────────────────────────────────
# Required. Used for chat responses, moderation, and source verification.
OPENAI_API_KEY=sk-...

# ── PostgreSQL (Railway) ─────────────────────────────────
# Required for RAG (pgvector) and message logging.
# Railway auto-injects DATABASE_URL. For local dev, use one of these:
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# Or individual DB_* vars:
# DB_HOST=localhost
# DB_USER=waterbot_admin
# DB_PASSWORD=localpass
# DB_NAME=waterbot_db
# DB_PORT=5432

# ── Transcript storage (local filesystem) ────────────────
# Optional. If omitted, transcripts are returned inline.
# TRANSCRIPT_STORAGE_PATH=/app/transcripts

# ── Session / Admin Auth ─────────────────────────────────
# Optional. If omitted, a random key is generated each restart (sessions won't survive restarts).
# SESSION_SECRET=

# ── Sources Verifier ─────────────────────────────────────
# Optional. Tune the source-verification LLM call.
# SOURCES_VERIFIER_MODEL=gpt-4o-mini
# SOURCES_VERIFIER_TIMEOUT=5.0
# SOURCES_VERIFIER_MAX_TOKENS=64
